{
  "name": "stackkit",
  "version": "0.3.6",
  "description": "Production-ready CLI to create and extend JavaScript or TypeScript apps with modular stacks.",
  "main": "dist/index.js",
  "bin": {
    "stackkit": "bin/stackkit.js"
  },
  "type": "commonjs",
  "files": [
    "dist",
    "bin",
    "templates",
    "modules"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tariqul420/stackkit.git",
    "directory": "apps/stackkit"
  },
  "homepage": "https://stackkit.tariqul.dev",
  "bugs": {
    "url": "https://github.com/tariqul420/stackkit/issues"
  },
  "scripts": {
    "dev": "tsc --watch",
    "bundle": "node ./scripts/bundle.js",
    "build": "pnpm run clean && tsc && pnpm run copy-assets && pnpm run bundle",
    "copy-assets": "node ./scripts/copy-assets.js",
    "clean": "node ./scripts/clean.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "stackkit",
    "cli",
    "project-generator",
    "scaffold",
    "boilerplate",
    "javascript",
    "typescript",
    "nextjs",
    "react",
    "vite",
    "express",
    "prisma",
    "mongoose",
    "mongodb",
    "postgresql",
    "authentication"
  ],
  "author": "Tariqul Islam",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "@types/prompts": "^2.4.9",
    "@types/validate-npm-package-name": "^4.0.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "esbuild": "^0.28.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "recast": "^0.23.11",
    "typescript": "^6.0.2",
    "validate-npm-package-name": "^7.0.2",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
