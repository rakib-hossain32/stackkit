{
  "name": "prisma",
  "type": "database",
  "priority": 5,
  "operations": [
    {
      "type": "create-file",
      "source": "prisma/schema.prisma",
      "destination": "prisma/schema.prisma"
    },
    {
      "type": "create-file",
      "source": "prisma.config.ts",
      "destination": "prisma.config.ts"
    },
    {
      "type": "create-file",
      "source": "lib/prisma.ts",
      "destination": "src/database/prisma.ts",
      "condition": { "framework": "express" }
    },
    {
      "type": "add-dependency",
      "dependencies": {
        "dotenv": "^17.4.2"
      }
    },
    {
      "type": "add-script",
      "scripts": {
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "prisma:seed": "tsx prisma/seed.ts",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio"
      }
    },
    {
      "type": "add-dependency",
      "condition": { "prismaProvider": "postgresql" },
      "dependencies": {
        "@prisma/client": "^7.8.0",
        "@prisma/adapter-pg": "^7.8.0",
        "pg": "^8.22.0"
      },
      "devDependencies": {
        "prisma": "^7.8.0"
      }
    },
    {
      "type": "add-env",
      "condition": { "prismaProvider": "postgresql" },
      "envVars": {
        "DATABASE_URL": "postgresql://username:password@localhost:5432/database_name"
      }
    },
    {
      "type": "add-dependency",
      "condition": { "prismaProvider": "mysql" },
      "dependencies": {
        "@prisma/client": "^7.8.0",
        "@prisma/adapter-mariadb": "^7.8.0",
        "mysql2": "^3.22.5"
      },
      "devDependencies": {
        "prisma": "^7.8.0"
      }
    },
    {
      "type": "add-env",
      "condition": { "prismaProvider": "mysql" },
      "envVars": {
        "DATABASE_URL": "mysql://username:password@localhost:3306/database_name"
      }
    },
    {
      "type": "add-dependency",
      "condition": { "prismaProvider": "sqlite" },
      "dependencies": {
        "@prisma/client": "^7.8.0",
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "better-sqlite3": "^12.11.1"
      },
      "devDependencies": {
        "prisma": "^7.8.0"
      }
    },
    {
      "type": "add-env",
      "condition": { "prismaProvider": "sqlite" },
      "envVars": {
        "DATABASE_URL": "file:./dev.db"
      }
    },
    {
      "type": "add-dependency",
      "condition": { "prismaProvider": "mongodb" },
      "dependencies": {
        "@prisma/client": "^7.8.0"
      },
      "devDependencies": {
        "prisma": "^7.8.0"
      }
    },
    {
      "type": "add-env",
      "condition": { "prismaProvider": "mongodb" },
      "envVars": {
        "DATABASE_URL": "mongodb://localhost:27017/database_name"
      }
    }
  ]
}